{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/easy-orchestration-harness/model-routing.schema.json",
  "title": "Model Routing",
  "type": "object",
  "required": ["policy", "worker_tiers", "phase_defaults"],
  "properties": {
    "policy": {
      "type": "object",
      "required": ["operators", "workers"]
    },
    "phase_defaults": {
      "type": "object",
      "required": [
        "planning",
        "design",
        "worker_brief_generation",
        "simple_code_implementation",
        "complex_code_implementation",
        "debugging",
        "evaluation",
        "cross_evaluation"
      ]
    }
    ,
    "worker_tiers": {
      "type": "object",
      "required": ["routine", "standard", "complex", "independent_evaluation"],
      "properties": {
        "routine": {
          "type": "object",
          "required": ["use_when", "preferred_session_for_simple_tasks", "example_model_classes", "reasoning_effort"]
        }
      }
    }
  }
}
