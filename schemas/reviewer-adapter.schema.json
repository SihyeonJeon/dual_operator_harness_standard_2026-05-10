{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reviewer Adapter",
  "type": "object",
  "required": [
    "id",
    "status",
    "type",
    "authority",
    "requires_redaction",
    "default_axes",
    "output_ledger"
  ],
  "properties": {
    "id": {"type": "string"},
    "status": {"type": "string"},
    "type": {"type": "string"},
    "authority": {"type": "string"},
    "requires_redaction": {"type": "boolean"},
    "requires_human_approval_for_private_data": {"type": "boolean"},
    "requires_scope_statement": {"type": "boolean"},
    "default_axes": {"type": "array", "items": {"type": "string"}},
    "output_ledger": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
