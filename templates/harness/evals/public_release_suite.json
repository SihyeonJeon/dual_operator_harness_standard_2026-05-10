    },
    {
      "id": "software_feedback_policy",
      "name": "Software feedback checks lint runtime browser and UI layout evidence",
      "type": "text_contains",
      "severity": "required",
      "path": "harness/shared/SOFTWARE_FEEDBACK_POLICY.md",
      "terms": ["lint", "runtime smoke", "Playwright", "UI/UX/layout", "NOT-RUN"]
    },
    {
      "id": "concept_translation_policy",
      "name": "User-facing output treats the request as concept not copy",
      "type": "text_contains",
      "severity": "required",
      "path": "harness/shared/CONCEPT_TRANSLATION_POLICY.md",
      "terms": ["Treat the user's request as intent", "Do not treat the request text as copy", "satisfy the concept without announcing", "concept-check"]
    },
    {
      "id": "current_market_research_policy",
      "name": "Current-state market research precedes overall planning when relevant",
      "type": "text_contains",
      "severity": "required",
      "path": "harness/shared/CURRENT_MARKET_RESEARCH_POLICY.md",
      "terms": ["Before the operator approves an overall plan", "as-of the command date", "CURRENT_RESEARCH.json", "current-research"]
    },
    {
      "id": "cross_feedback_loop_policy",
      "name": "Cross feedback loop records independent feedback before closure",
      "type": "text_contains",
      "severity": "required",
      "path": "harness/shared/CROSS_FEEDBACK_LOOP.md",
      "terms": ["independent feedback path", "Material dissent is preserved", "Do not forward full transcripts", "cross-feedback"]
    },
    {
      "id": "harnessctl_executable_governance_commands",
      "name": "Harness control surface includes executable context routing and feedback helpers",
      "type": "text_contains",
      "severity": "required",
      "path": "scripts/harnessctl.py",
      "terms": ["context-pack", "worker-brief", "model-route", "task-packet", "current-research", "cross-feedback", "concept-check", "software-feedback", "preregister-benchmark", "blind-redact", "council-decision", "recovery-evidence"]
    },
    {
      "id": "recovery_restart_path",
      "name": "Failure recovery uses checkpoints and restart files",
      "type": "text_contains",
      "severity": "required",
      "path": "harness/shared/SESSION_CONTINUITY.md",
