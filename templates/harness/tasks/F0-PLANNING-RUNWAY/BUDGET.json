{
  "task_id": "F0-PLANNING-RUNWAY",
  "token_cap": "project_defined_before_dispatch",
  "time_cap_minutes": 180,
  "cost_cap_usd": "project_defined_before_dispatch",
  "warning_threshold_percent": 80,
  "kill_threshold_percent": 100,
  "kill_procedure": "Stop worker dispatch, summarize current planning state, and escalate to fixed operators.",
  "usage_event_fields": [
    "token_used",
    "time_elapsed_minutes",
    "cost_used_usd",
    "budget_percent",
    "budget_status"
  ],
  "enforcement": {
    "local_command": "python3 scripts/harnessctl.py budget-check --task-id F0-PLANNING-RUNWAY",
    "warning_event_type": "budget.warning",
    "kill_event_type": "budget.kill_required",
    "runner_must_stop_on_kill": true
  },
  "escalation": {
    "operator_required": true,
    "human_required_for_budget_increase": true,
    "event_type": "budget.escalation_required"
  }
}
